{
  "name": "claude-ltm-plugin",
  "version": "2.0.2",
  "description": "Long-Term Memory plugin for Claude Code",
  "private": true,
  "workspaces": ["packages/*"],
  "type": "module",
  "scripts": {
    "bump": "bun run scripts/bump-version.ts",
    "verify-version": "bun run scripts/verify-version-sync.ts",
    "typecheck": "bunx tsc --noEmit",
    "dev:mcp": "bun run src/mcp-server.ts",
    "dev:server": "LTM_DB_PATH=./data/ltm.db bun run src/graph-server.ts",
    "migrate": "LTM_DB_PATH=./data/ltm.db bun run src/migrate.ts",
    "test": "bun test --path-ignore-patterns='graph-app/**' --pass-with-no-tests",
    "test:e2e": "cd graph-app && bunx playwright test",
    "postinstall": "bun run scripts/update-wiring.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "@modelcontextprotocol/sdk": "^1.27.1",
    "@rohirik/ltm-core": "workspace:*",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "bun-types": "^1.0.0",
    "esbuild": "^0.25.0",
    "typescript": "^5.4.0"
  },
  "overrides": {
    "path-to-regexp": "^8.4.0",
    "hono": "^4.12.12",
    "@hono/node-server": "^1.19.13",
    "fast-uri": "^3.1.2"
  }
}
