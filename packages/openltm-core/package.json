  "description": "Shared LTM storage engine — path-agnostic SQLite core used by Claude Code, OpenCode, and Pi adapters",
  "type": "module",
  "main": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./cli": "./src/cli/index.ts",
    "./mcp": "./src/mcp/server.ts"
  },
  "bin": {
