{
  "name": "@rohirik/pi-ltm",
  "version": "2.7.0",
  "description": "LTM (Long-Term Memory) native extension for Pi — share memories with Claude Code and OpenCode",
  "type": "module",
  "main": "./dist/index.js",
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "dist",
    "src"
  ],
  "pi": {
    "extensions": [
      "./dist/index.js"
    ]
  },
  "scripts": {
    "build": "bunx esbuild src/index.ts --bundle --platform=node --format=esm --target=esnext --outfile=dist/index.js --external:bun:sqlite --external:bun:test --external:@rohirik/openltm-core --minify",
    "prepublishOnly": "bun run build",
    "typecheck": "bunx tsc --noEmit",
    "test": "bun test"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/RohiRIK/OpenLtm"
  },
  "keywords": [
    "pi",
    "pi-coding-agent",
    "ltm",
    "long-term-memory",
    "extension"
  ],
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "dependencies": {
    "@rohirik/openltm-core": "workspace:*"
  },
  "peerDependencies": {
    "bun-types": ">=1.0.0"
  },
  "peerDependenciesMeta": {
    "bun-types": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/bun": "latest"
  }
}
