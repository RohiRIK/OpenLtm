# TruffleHog --exclude-paths uses Go regexp (one pattern per line), NOT globs.
# Glob patterns like *.lock are invalid regex and abort the scan.
# .aegis/ holds prior scan outputs; scanning them re-flags every URI/secret in
# past JSON results (128 false "secrets" in audit 2026-06-06). Must be excluded.
.aegis/
\.git/
node_modules/
dist/
build/
\.lock$
\.tar$
\.tar\.gz$
\.zip$
\.gz$
\.whl$
\.egg$
