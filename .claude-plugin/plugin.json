{
  "name": "ltm",
  "description": "OpenLTM — Long-Term Memory for AI coding agents: semantic search, context injection, session learning",
  "version": "2.7.5",
  "author": {
    "name": "RohiRIK"
  },
  "mcpServers": {
    "memory": {
      "command": "bun",
      "args": [
        "run",
        "${CLAUDE_PLUGIN_ROOT}/src/mcp-server.ts"
      ],
      "env": {
        "LTM_DB_PATH": "${CLAUDE_PLUGIN_DATA}/ltm.db"
      }
    }
  },
  "skills": "./skills/",
  "agents": [
    "./agents/git-learner.md",
    "./agents/planner.md"
  ]
}
